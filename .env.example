# HuggingFace
# Required for gated models (e.g. meta-llama/*).
HF_TOKEN=

# Override default HF cache location (defaults to ~/.cache/huggingface).
# HF_HOME=./hf_cache

# vLLM logging verbosity: DEBUG | INFO | WARNING | ERROR
# VLLM_LOGGING_LEVEL=INFO

# Optional: pin a CUDA visible device when running on multi-GPU hosts.
# CUDA_VISIBLE_DEVICES=0
